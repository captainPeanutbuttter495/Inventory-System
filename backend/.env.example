# Copy this file to .env and fill in real values for local dev.
# .env is gitignored and excluded from the Docker image (.dockerignore);
# values are injected into the container at run time via: docker run --env-file .env
#
# Required. No default — a missing SECRET_KEY crashes Django at startup on purpose.
SECRET_KEY=
# "True"/"False" (string). Defaults to False if unset. Use True for local dev only.
DEBUG=False
# Comma-separated, no spaces. Required when DEBUG=False.
ALLOWED_HOSTS=127.0.0.1,localhost
